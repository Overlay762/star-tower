{
  "compilerOptions": {
    "target": "ES2015",
    "module": "ES2015",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./assets",
    "types": [
      "cocos-creator"
    ]
  },
  "include": [
    "assets/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
